# LLM providers (at least one required for live runs)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default model (override in CLI/Streamlit) — must match the API key you set below
LOG_TRIAGE_DEFAULT_MODEL=gpt-4o-mini
LOG_TRIAGE_DEFAULT_PROMPT_VERSION=v3

# Optional: explicit provider when model id is new (openai | anthropic)
# LOG_TRIAGE_PROVIDER=openai

# Optional: judge reviewer model (defaults to LOG_TRIAGE_DEFAULT_MODEL if unset)
# LOG_TRIAGE_JUDGE_MODEL=gpt-4o-mini

# Response cache (golden-set reruns)
LOG_TRIAGE_CACHE_DIR=.cache/llm-log-triage

# Observability — langsmith default for tracing + offline experiments
# none | langsmith | otel
OBS_BACKEND=langsmith

# LangSmith (required when OBS_BACKEND=langsmith)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=llm-log-triage
LOG_TRIAGE_LANGSMITH_DATASET=log-triage-golden-set-v3
LOG_TRIAGE_LANGSMITH_EVAL_MAX_CASES=5

# OTel — only when OBS_BACKEND=otel
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# GitHub Actions CI — Settings → Secrets and variables → Actions
#   Secrets: OPENAI_API_KEY and/or ANTHROPIC_API_KEY (matching your CI model)
#   Variable: LOG_TRIAGE_CI_MODEL (default gpt-4o-mini if unset)
#   Variable: LOG_TRIAGE_CI_PROVIDER (optional — openai | anthropic for new model ids)
# Workflows use: python -m llm_log_triage.providers --check-secrets
